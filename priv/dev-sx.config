%-*-Erlang-*-
[{setup, [{data_dir, "/var/lib/smf"},
	  {log_dir,  "/var/log/smf-c-node"}
	 ]},

 {kernel,
  [{logger,
    [{handler, default, logger_std_h,
      #{level => info,
	config =>
	    #{sync_mode_qlen => 10000,
	      drop_mode_qlen => 10000,
	      flush_qlen     => 10000}
       }
     }
    ]}
  ]},

 {smf_core, [
    {node, #{node_id => <<"pgw.epc.mnc001.mcc001.3gppnetwork.org">>}},
    {sockets, #{
	irx => #{type => 'gtp-c', ip => {172,20,16,55}, freebind => true},
	grx => #{type => 'gtp-u', ip => {172,20,16,55}},
	cp => #{type => 'gtp-u', vrf => cp, ip => {127,0,0,1},
		freebind => true, reuseaddr => true},
	sx => #{node => smf, name => smf, type => pfcp,
		socket => cp, ip => {0,0,0,0}}
    }},
    {handlers, #{
	h1 => #{handler => pgw_s5s8, protocol => gn,
		sockets => [irx], node_selection => [default],
		aaa => #{'Username' =>
		    #{default => ['IMSI', <<"@">>, 'APN']}}},
	h2 => #{handler => pgw_s5s8, protocol => s5s8,
		sockets => [irx], node_selection => [default]}
    }},
    {http_api, #{port => 8080, ip => {0,0,0,0}}}
  ]},

 {smf, [{'$setup_vars',
	  [{"ORIGIN", {value, "epc.mnc001.mcc001.3gppnetwork.org"}}]},

	 {dp_handler, smf_sx_bin},

	 {ip_pools,
	  [{upstream, [{ranges, [{{10, 180, 0, 1}, {10, 180, 255, 254}, 32},
				 {{16#8001, 0, 0, 0, 0, 0, 0, 0},
				  {16#8001, 0, 0, 16#FFFF, 0, 0, 0, 0}, 64}
				]},
		       {'MS-Primary-DNS-Server', {8,8,8,8}},
		       {'MS-Secondary-DNS-Server', {8,8,4,4}},
		       {'MS-Primary-NBNS-Server', {127,0,0,1}},
		       {'MS-Secondary-NBNS-Server', {127,0,0,1}}
		      ]}
	  ]},

	 {nodes,
	  [{default,
	    [{vrfs,
	      [{cp, [{features, ['CP-Function']}]},
	       {epc, [{features, ['Access']}]},
	       {sgi, [{features, ['SGi-LAN']}]}]
	     },
	     {heartbeat, [
	         {interval, 5000},
	         {timeout, 500},
	         {retry, 5}
	     ]},
	     {request,
	         [{timeout, 30000},
	         {retry, 5}]}]
	   }]
	 },

	 {node_selection,
	  [{default,
	    {static,
	     [
	      {"_default.apn.$ORIGIN", {300,64536},
	       [{"x-3gpp-upf","x-sxb"}],
	       "topon.sx.prox01.$ORIGIN"},

	      {"apn01.example.net.apn.$ORIGIN", {300,64536},
	       [{"x-3gpp-upf","x-sxb"}],
	       "topon.sx.prox01.$ORIGIN"},

	      {"topon.sx.prox01.$ORIGIN", [{127,0,0,1}], []}
	     ]
	    }
	   }
	  ]
	 },

	 {apns,
	  [{[<<"tpip">>, <<"net">>], [{vrf, upstream}]},
	   {[<<"APN1">>], [{vrf, upstream}]}
	  ]}
	]},

 {exometer_core, [{reporters, [{exometer_report_netdata, []}]}]},

 {smf_aaa, [
	     {smf_aaa_provider, {smf_aaa_mock, [{shared_secret, <<"MySecret">>}]}}
	    ]},

 {hackney, [
	    {mod_metrics, exometer}
	    ]},

 {jobs, [{samplers,
	  [{cpu_feedback, jobs_sampler_cpu, []}
	  ]},
	 {queues,
	  [{path_restart,
	    [{regulators, [{counter, [{limit, 100}]}]},
	     {modifiers,  [{cpu_feedback, 10}]}
	    ]},
	   {create,
	    [{max_time, 5000},
	     {regulators, [{rate, [{limit, 100}]}]},
	     {modifiers,  [{cpu_feedback, 10}]}
	    ]},
	   {delete,
	    [{regulators, [{counter, [{limit, 100}]}]},
	     {modifiers,  [{cpu_feedback, 10}]}
	    ]},
	   {other,
	    [{max_time, 10000},
	     {regulators, [{rate, [{limit, 1000}]}]},
	     {modifiers,  [{cpu_feedback, 10}]}
	    ]}
	  ]}
	]}
].
