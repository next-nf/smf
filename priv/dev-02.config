%-*-Erlang-*-
[{setup, [{data_dir, "/var/lib/smf"},
	  {log_dir,  "/var/log/smf-c-node"}
	 ]},

 {kernel,
  [{logger_level, info},
   {logger,
    [{handler, default, logger_std_h,
      #{level => debug,
	formatter =>
	    {logger_formatter,
	     #{single_line => true,
	       legacy_header => false,
	       template => [time," ",pid," ",level,": ",msg,"\n"]
	      }},
	config =>
	    #{sync_mode_qlen => 10000,
	      drop_mode_qlen => 10000,
	      flush_qlen     => 10000}
       }
     }
    ]}
  ]},

 {smf_core, [
    {node, #{node_id => <<"pgw-02.epc.mnc001.mcc001.3gppnetwork.org">>,
	     teid => {2, 4}}},
    {sockets, #{
	cp => #{type => 'gtp-u', vrf => cp, ip => {127,0,1,2},
		reuseaddr => true, freebind => true},
	irx => #{type => 'gtp-c', vrf => epc, ip => {127,0,1,2},
		 cluster_ip => {172,20,16,28}, reuseaddr => true},
	sx => #{type => pfcp, socket => cp, ip => {127,0,1,2},
		reuseaddr => true}
    }},
    {handlers, #{
	h1 => #{handler => pgw_s5s8, protocol => gn,
		sockets => [irx], node_selection => [default]},
	h2 => #{handler => pgw_s5s8, protocol => s5s8,
		sockets => [irx], node_selection => [default]}
    }},
    {http_api, #{port => 8080, ip => {127,0,1,2}}}
  ]},

 {smf, [{'$setup_vars',
	  [{"ORIGIN", {value, "epc.mnc001.mcc001.3gppnetwork.org"}}]},

	 {cluster, [{enabled, true},
		    {seed_nodes, ['smf-c-node-01@zeus',
				  'smf-c-node-02@zeus',
				  'smf-c-node-03@zeus']}]},

	 {ip_pools,
	  [{'SGi',  [{ranges, [{{10, 106, 0, 1}, {10, 106, 255, 254}, 32},
			       {{16#8001, 0, 0, 0, 0, 0, 0, 0},
				{16#8001, 0, 0, 16#FFFF, 0, 0, 0, 0}, 64}
			      ]},
		     {'MS-Primary-DNS-Server', {8,8,8,8}},
		     {'MS-Secondary-DNS-Server', {8,8,4,4}},
		     {'MS-Primary-NBNS-Server', {127,0,0,1}},
		     {'MS-Secondary-NBNS-Server', {127,0,0,1}}
		    ]}
	  ]},

	 {apns,
	  [{[<<"tpip">>, <<"net">>], [{vrf, sgi}, {ip_pools, ['SGi']}]},
	   {[<<"APN1">>], [{vrf, sgi}, {ip_pools, ['SGi']}]},
	   {'_', [{vrf, sgi}, {ip_pools, ['SGi']}]}
	  ]},

	 {node_selection,
	  [{default,
	    {static,
	     [
	      {"_default.apn.$ORIGIN", {300,64536},
	       [{"x-3gpp-pgw","x-s5-gtp"},{"x-3gpp-pgw","x-s8-gtp"},
		{"x-3gpp-pgw","x-gn"},{"x-3gpp-pgw","x-gp"}],
	       "topon.s5s8.pgw.$ORIGIN"},
	      {"_default.apn.$ORIGIN", {300,64536},
	       [{"x-3gpp-upf","x-sxb"}],
	       "topon.sx.prox01.$ORIGIN"},

	      {"web.apn.$ORIGIN", {300,64536},
	       [{"x-3gpp-pgw","x-s5-gtp"},{"x-3gpp-pgw","x-s8-gtp"},
		{"x-3gpp-pgw","x-gn"},{"x-3gpp-pgw","x-gp"}],
	       "topon.s5s8.pgw.$ORIGIN"},
	      {"web.apn.$ORIGIN", {300,64536},
	       [{"x-3gpp-upf","x-sxb"}],
	       "topon.sx.prox01.$ORIGIN"},

	      {"topon.s5s8.pgw.$ORIGIN",  [{172, 20, 16, 28}], []},
	      {"topon.sx.prox01.$ORIGIN", [{127, 0, 100, 1}], []}
	     ]
	    }
	   }
	  ]
	 },

	 {charging,
	  [{default,
	    [{rulebase,
	      [{<<"r-0001">>,
		#{'Rating-Group' => [3000],
		  'Flow-Information' =>
		      [#{'Flow-Description' => [<<"permit out ip from any to assigned">>],
			 'Flow-Direction'   => [1]},
		       #{'Flow-Description' => [<<"permit out ip from any to assigned">>],
			 'Flow-Direction'   => [2]}],
		  'Metering-Method'  => [1],
		  'Precedence' => [100],
		  'Online'  => [0],
		  'Offline'  => [1]
		 }},
	       {<<"r-0002">>,
		#{'Rating-Group' => [1000],
		  'TDF-Application-Identifier' => [<<"Gold">>],
		  'Metering-Method'  => [1],
		  'Precedence' => [20],
		  'Online'  => [0],
		  'Offline'  => [1]
		 }},
	       {<<"r-0003">>,
		#{'Rating-Group' => [2000],
		  'TDF-Application-Identifier' => [<<"Silver">>],
		  'Metering-Method'  => [1],
		  'Precedence' => [50],
		  'Online'  => [0],
		  'Offline'  => [1]
		 }},
	       {<<"m2m0001">>, [<<"r-0001">>, <<"r-0002">>, <<"r-0003">>]}
	      ]}
	    ]}
	  ]},

	 {nodes,
	  [{default,
	    [{vrfs,
	      [{cp, [{features, ['CP-Function']}]},
	       {epc, [{features, ['Access']}]},
	       {sgi, [{features, ['SGi-LAN']}]}]
	     },
	     {ip_pools, ['SGi']}
	    ]},
	   {"topon.sx.prox01.$ORIGIN", [connect]}
	  ]
	 }
	]},

 {smf_aaa,
  [{handlers,
    [{smf_aaa_static,
	[{'NAS-Identifier',          <<"NAS-Identifier">>},
	 {'Framed-Protocol',         'PPP'},
	 {'Service-Type',            'Framed-User'},
	 {'Node-Id',                 <<"PGW-001">>},
	 {'Charging-Rule-Base-Name', <<"m2m0001">>},
	 {'Offline-Charging-Profile',
	  #{'Default' => #{'Tariff-Time' => {13, 20}}}}
	]}
    ]},

   {services,
    [{'Default', [{handler, 'smf_aaa_static'},
		  {answers,
		   #{'Initial-Rf' =>
			 #{'Result-Code' => 2001},
		     'Update-Rf' => #{'Result-Code' => 2001},
		     'Final-Rf' => #{'Result-Code' => 2001},
		     'Initial-Gx' =>
			 #{'Result-Code' => 2001,
			   'Charging-Rule-Install' =>
			       [#{'Charging-Rule-Base-Name' => [<<"m2m0001">>]}]
			  },
		     'Update-Gx' => #{'Result-Code' => 2001},
		     'Final-Gx' => #{'Result-Code' => 2001},
		     'Initial-OCS' =>
			 #{'Result-Code' => 2001,
			   'Multiple-Services-Credit-Control' =>
			       [#{'Envelope-Reporting' => [0],
				  'Granted-Service-Unit' =>
				      [#{'CC-Time' => [3600],
					 'CC-Total-Octets' => [102400]}],
				  'Rating-Group' => [1000],
				  'Result-Code' => [2001],
				  'Time-Quota-Threshold' => [60],
				  'Volume-Quota-Threshold' => [10240]},
				#{'Envelope-Reporting' => [0],
				  'Granted-Service-Unit' =>
				      [#{'CC-Time' => [3600],
					 'CC-Total-Octets' => [102400]}],
				  'Rating-Group' => [2000],
				  'Result-Code' => [2001],
				  'Time-Quota-Threshold' => [60],
				  'Volume-Quota-Threshold' => [10240]},
				#{'Envelope-Reporting' => [0],
				  'Granted-Service-Unit' =>
				      [#{'CC-Time' => [3600],
					 'CC-Total-Octets' => [102400]}],
				  'Rating-Group' => [3000],
				  'Result-Code' => [2001],
				  'Time-Quota-Threshold' => [60],
				  'Volume-Quota-Threshold' => [10240]}
			       ]
			  },
		     'Update-OCS' => #{'Result-Code' => 2001},
		     'Final-OCS' => #{'Result-Code' => 2001}
		    }
		  }
		 ]}
    ]},

   {apps,
    [{default,
      [{session, ['Default']},
       {procedures, [{authenticate, []},
		     {authorize, []},
		     {start, []},
		     {interim, []},
		     {stop, []},

		     {{rf, 'Initial'},   [{'Default', [{answer, 'Initial-Rf'}]}]},
		     {{rf, 'Update'},    [{'Default', [{answer, 'Update-Rf'}]}]},
		     {{rf, 'Terminate'}, [{'Default', [{answer, 'Final-Rf'}]}]},

		     {{gx, 'CCR-Initial'},   [{'Default', [{answer, 'Initial-Gx'}]}]},
		     {{gx, 'CCR-Update'},    [{'Default', [{answer, 'Update-Gx'}]}]},
		     {{gx, 'CCR-Terminate'}, [{'Default', [{answer, 'Final-Gx'}]}]},

		     {{gy, 'CCR-Initial'},   []},
		     {{gy, 'CCR-Update'},    []},
		     {{gy, 'CCR-Terminate'}, []}
		    ]}
      ]}
    ]}
 ]},

 {jobs, [{samplers,
	  [{cpu_feedback, jobs_sampler_cpu, []}
	  ]},
	 {queues,
	  [{path_restart,
	    [{regulators, [{counter, [{limit, 100}]}]},
	     {modifiers,  [{cpu_feedback, 10}]}
	    ]},
	   {create,
	    [{max_time, 5000},
	     {regulators, [{rate, [{limit, 100}]}]},
	     {modifiers,  [{cpu_feedback, 10}]}
	    ]},
	   {delete,
	    [{regulators, [{counter, [{limit, 100}]}]},
	     {modifiers,  [{cpu_feedback, 10}]}
	    ]},
	   {other,
	    [{max_time, 10000},
	     {regulators, [{rate, [{limit, 1000}]}]},
	     {modifiers,  [{cpu_feedback, 10}]}
	    ]}
	  ]}
	]}
].
