%-*-Erlang-*-
%% Dynamic configuration — loaded from YAML at runtime.
%% This file is a legacy reference. In production, use a YAML config
%% pointed to by {smf, [{config, #{file => "...", type => yaml}}]}
%% in sys.config.
%%
%% Static config (node, sockets, handlers, http_api) belongs in
%% sys.config under {smf_core, [...]}.

[{smf, [
	 {'$setup_vars',
	  [{"ORIGIN", {value, "epc.mnc001.mcc001.3gppnetwork.org"}}]},

	 {ip_pools,
	  [{sgi, [{pools,  [{{10, 180, 0, 1}, {10, 180, 255, 254}, 32},
			    {{16#8001, 0, 0, 0, 0, 0, 0, 0},
			     {16#8001, 0, 0, 16#FFFF, 0, 0, 0, 0}, 64}
			   ]},
		  {'MS-Primary-DNS-Server', {8,8,8,8}},
		  {'MS-Secondary-DNS-Server', {8,8,4,4}},
		  {'MS-Primary-NBNS-Server', {127,0,0,1}},
		  {'MS-Secondary-NBNS-Server', {127,0,0,1}}
		 ]}
	  ]},

	 {apns,
	  [{[<<"apn01">>,<<"example">>,<<"net">>], [{vrf, sgi}]},
	   {[<<"apn02">>,<<"example">>,<<"net">>], [{vrf, sgi}]}
	  ]},

	 {node_selection,
	  [{default,
	    {static,
	     [
	      {"_default.apn.$ORIGIN", {300,64536},
	       [{"x-3gpp-upf","x-sxb"}],
	       "topon.sx.prox01.$ORIGIN"},

	      {"apn01.example.net.apn.$ORIGIN", {300,64536},
	       [{"x-3gpp-upf","x-sxb"}],
	       "topon.sx.prox01.$ORIGIN"},

	      {"topon.sx.prox01.$ORIGIN", [{127,0,0,1}], []}
	     ]
	    }
	   }
	  ]
	 },

	 {nodes,
	  [{default,
	    [{vrfs,
	      [{cp, [{features, ['CP-Function']}]},
	       {epc, [{features, ['Access']}]},
	       {sgi, [{features, ['SGi-LAN']}]}]
	     },
	     {heartbeat, [
	         {interval, 5000},
	         {timeout, 500},
	         {retry, 5}
	     ]},
	     {request,
	         [{timeout, 30000},
	         {retry, 5}]}]
	   }]
	 },

	 {path_management,
	  [{t3, 10000},
	   {n3,  5},
	   {echo, 60000},
	   {idle_timeout, 1800000},
	   {idle_echo,     600000},
	   {down_timeout, 3600000},
	   {down_echo,     600000}
	  ]}
	]},

 {smf_aaa,
  [{handlers,
    [{smf_aaa_static,
	[{'NAS-Identifier',        <<"NAS-Identifier">>},
	 {'Acct-Interim-Interval', 600},
	 {'Framed-Protocol',       'PPP'},
	 {'Service-Type',          'Framed-User'}]}
    ]},

   {services,
    [{'Default', [{handler, 'smf_aaa_static'}]}
    ]},

   {apps,
    [{default,
      [{session, ['Default']},
       {procedures, [{authenticate, []},
		     {authorize, []},
		     {start, []},
		     {interim, []},
		     {stop, []}]}
      ]}
    ]}
  ]},

 {jobs, [{queues,
	  [{path_restart,
	    [{path_restart, [{standard_counter, 100}]},
	     {create, [{standard_rate, 100}, {max_size, 10}]},
	     {delete, [{standard_counter, 100}]},
	     {other, [{standard_rate, 100}, {max_size, 10}]}
	    ]}
	  ]}
	]}
].
