%-*-Erlang-*-
[{ergw_core, [
    {node, #{node_id => <<"pgw.epc.mnc001.mcc001.3gppnetwork.org">>,
             plmn_id => #{mcc => <<"001">>, mnc => <<"01">>}}},

    {sockets, #{
        cp => #{type => 'gtp-u', vrf => cp, ip => {127,0,0,1},
                freebind => true, reuseaddr => true},
        irx => #{type => 'gtp-c', ip => {127,0,0,1},
                 netdev => "grx", freebind => true},
        sx => #{node => ergw, name => ergw, type => pfcp,
                socket => cp, ip => {172,21,16,2}}
    }},

    {handlers, #{
        h1 => #{handler => pgw_s5s8, protocol => gn,
                sockets => [irx], node_selection => [default],
                aaa => #{'Username' =>
                    #{default => ['IMSI', <<"@">>, 'APN']}}},
        h2 => #{handler => pgw_s5s8, protocol => s5s8,
                sockets => [irx], node_selection => [default]}
    }},

    {http_api, #{port => 8000, ip => {127,0,0,1}}}
  ]},

 {ergw, [
    {config, #{file => "/etc/ergw-c-node/ergw.yaml", type => yaml}}
  ]},

 {setup, [{data_dir, "/var/lib/ergw"},
          {log_dir,  "/var/log/ergw-c-node"}]},

 {kernel,
  [{logger,
    [{handler, default, logger_std_h,
      #{level => info,
        config =>
            #{sync_mode_qlen => 10000,
              drop_mode_qlen => 10000,
              flush_qlen     => 10000}
       }
     }
    ]}
  ]}
].
